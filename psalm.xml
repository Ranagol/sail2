<?xml version="1.0"?>
<psalm
    totallyTyped="false"
    errorLevel="4"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    findUnusedCode="true"
    showInfo="true"
    arrayCache="false"
>
    <projectFiles>
        <directory name="app"/>
        <directory name="routes"/>
        <directory name="database"/>
        <directory name="tests"/>
        <ignoreFiles>
            <directory name="vendor"/>
            <directory name="node_modules"/>
        </ignoreFiles>
    </projectFiles>

    <plugins>
        <pluginClass class="Psalm\LaravelPlugin\Plugin"/>
        <pluginClass class="Psalm\PhpUnitPlugin\Plugin"/>
    </plugins>

    <issueHandlers>
        <ClassMustBeFinal errorLevel="suppress"/>
        <MixedAssignment errorLevel="info"/>
        <MixedArgument errorLevel="info"/>
        <MixedReturnStatement errorLevel="info"/>
        <UndefinedClass errorLevel="info"/>
        <UndefinedMethod errorLevel="info"/>
        <PossiblyUndefinedMethod errorLevel="info"/>
        <PossiblyNullReference errorLevel="info"/>
        <PossiblyUnusedMethod>
            <errorLevel type="suppress">
                <directory name="app/Http/Controllers"/>
                <directory name="app/Http/Requests"/>
                <directory name="app/Jobs"/>
                <directory name="app/Mail"/>
            </errorLevel>
        </PossiblyUnusedMethod>
        <UnusedClass>
            <errorLevel type="suppress">
                <directory name="app/Http/Controllers"/>
                <directory name="app/Providers"/>
                <directory name="database/seeders"/>
            </errorLevel>
        </UnusedClass>
        <PossiblyUnusedParam>
            <errorLevel type="suppress">
                <directory name="app/Http/Controllers"/>
            </errorLevel>
        </PossiblyUnusedParam>
        <UndefinedMagicPropertyFetch>
            <errorLevel type="suppress">
                <directory name="app"/>
                <directory name="tests"/>
                <directory name="database/factories"/>
            </errorLevel>
        </UndefinedMagicPropertyFetch>
        <InvalidScope>
            <errorLevel type="suppress">
                <file name="routes/console.php"/>
            </errorLevel>
        </InvalidScope>
    </issueHandlers>
</psalm>
